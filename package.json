{
  "name": "torlnk",
  "version": "1.4.3",
  "description": "A sleek torrent finder and downloader with a modern GUI (Tauri + librqbit).",
  "type": "module",
  "bin": {
    "torlnk": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "preview"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "dev:tui": "tsx src/index.tsx --tui",
    "dev:gui": "vite",
    "dev:search": "tsx scripts/dev-search.ts",
    "dev:stack": "node scripts/dev-before.mjs",
    "dev:tauri": "tauri dev",
    "build": "tsup",
    "build:gui": "vite build",
    "build:sidecar": "tsup --config tsup.sidecar.config.ts",
    "build:sidecar:bin": "node scripts/build-sidecar-bin.mjs",
    "build:tauri": "tauri build",
    "postbuild": "node scripts/postbuild.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "sync:check": "node scripts/sync-check.mjs",
    "verify:seeding": "tsx scripts/verify-seeding.ts",
    "previews": "tsx scripts/render-previews.tsx",
    "prepublishOnly": "npm run build && npm run build:gui && npm run build:sidecar"
  },
  "keywords": [
    "torrent",
    "torrent-client",
    "torrent-search",
    "downloader",
    "magnet",
    "magnet-links",
    "p2p",
    "librqbit",
    "tauri",
    "gui",
    "seeding",
    "tui",
    "terminal",
    "cli",
    "ink",
    "zero-configuration",
    "zero-setup",
    "fitgirl"
  ],
  "author": "Domanffe",
  "license": "MIT",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Domanffe/torlink-gui.git"
  },
  "homepage": "https://github.com/Domanffe/torlink-gui#readme",
  "bugs": {
    "url": "https://github.com/Domanffe/torlink-gui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.3.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "env-paths": "^4.0.0",
    "ink": "^7.0.5",
    "motion": "^12.42.2",
    "parse-torrent": "^11.0.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  }
}
