{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "torlink",
  "version": "1.4.0",
  "identifier": "app.torlink.desktop",
  "build": {
    "frontendDist": "../dist/gui",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:search",
    "beforeBuildCommand": "npm run build:gui && npm run build:sidecar && npm run build:sidecar:bin"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "torlink",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/search-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
